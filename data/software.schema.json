{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software documented across institutions",
  "type": "object",
  "additionalProperties": false,
  "required": ["software", "institutions", "category", "tool_type"],
  "properties": {
    "software": {
      "type": "string",
      "minLength": 1,
      "x-display": {
        "label": "Software",
        "type": "tag",
        "class": "tag--soft",
        "sort": "text"
      }
    },
    "institutions": {
      "type": "string",
      "x-display": {
        "label": "Used by",
        "type": "text",
        "sort": "number",
        "count_prefix": true,
        "filter": "multi"
      }
    },
    "category": {
      "type": "string",
      "x-display": {
        "label": "Category",
        "type": "tag",
        "sort": "text",
        "filter": "select"
      }
    },
    "tool_type": {
      "type": "string",
      "enum": ["Academic Tool", "Administrative Tool", "Other"],
      "x-display": { "label": "Type", "type": "tag", "sort": "text" }
    }
  }
}
